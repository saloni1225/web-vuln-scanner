# AdaptiveScan — Environment Configuration Template
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit .env to git. It is listed in .gitignore.

# ── JWT Secret ────────────────────────────────────────────────────────────────
# 64 random hex characters. Generate with: python scripts/rotate_jwt_secret.py
# CRITICAL: Must be at least 32 bytes of entropy. The fallback dev secret is INSECURE.
ADAPTIVESCAN_JWT_SECRET=REPLACE_WITH_64_HEX_CHARS

# ── Cookie Security ───────────────────────────────────────────────────────────
# Set to true in production (requires HTTPS). false is only safe on localhost.
COOKIE_SECURE=false

# ── API Docs (Swagger / ReDoc) ────────────────────────────────────────────────
# Set to false in production to hide the interactive API docs.
ADAPTIVESCAN_EXPOSE_DOCS=true

# ── HSTS (HTTP Strict Transport Security) ─────────────────────────────────────
# Set to true when running behind HTTPS. Requires COOKIE_SECURE=true.
ADAPTIVESCAN_HSTS=false

# ── Admin User Seeding ────────────────────────────────────────────────────────
# WARNING: Only enable this for initial setup. Disable immediately after.
# Never set ADAPTIVESCAN_SEED_ADMIN=true in long-running production environments.
# Leave ADAPTIVESCAN_SEED_ADMIN unset (or false) in production.
ADAPTIVESCAN_SEED_ADMIN=false
ADAPTIVESCAN_SEED_EMAIL=admin@your-domain.com
ADAPTIVESCAN_SEED_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── CORS Origins ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Default: http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
