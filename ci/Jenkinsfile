pipeline {
  agent any
  stages {
    stage('Install') {
      steps {
        sh 'python -m pip install --upgrade pip'
        sh 'python -m pip install -r requirements.txt'
        dir('frontend') {
          sh 'npm ci'
        }
      }
    }
    stage('Validate') {
      steps {
        sh 'python -m pytest'
        dir('frontend') {
          sh 'npm run build'
        }
      }
    }
  }
  post {
    always {
      archiveArtifacts artifacts: 'backend/reports/exports/*', allowEmptyArchive: true
    }
  }
}

